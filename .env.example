# =====================================================================
# Kovalyx — environment configuration template
#
# Copy this file to `.env` and fill in real values locally. `.env` is
# git-ignored and MUST NEVER be committed. In production, none of these
# secrets live in this file at all — deploy/oracle_cloud_setup.sh seeds
# them into HashiCorp Vault via scripts/vault_init.py, and every service
# (Airflow, PySpark, dbt) pulls them from Vault at runtime via `hvac`.
# This file exists only to document which variables exist and what they
# are for. No real credentials belong here, ever.
# =====================================================================

# ---------------------------------------------------------------------
# Vault
# ---------------------------------------------------------------------
# Address of the Vault server. Not secret — safe to keep as-is for local dev.
# `vault` only resolves as a hostname *inside* the Docker network — every
# containerized service (Airflow, Spark, dbt) uses this value correctly.
# Running scripts/vault_init.py directly from your own host shell (not in
# a container) needs http://localhost:8200 instead; override it for that
# one invocation rather than changing this file:
#   PowerShell: $env:VAULT_ADDR = "http://localhost:8200"
#   bash:       VAULT_ADDR=http://localhost:8200 python scripts/vault_init.py --mode dev
VAULT_ADDR=http://vault:8200
# Dev-mode root token (local only). In production Vault is unsealed via
# scripts/vault_init.py and the resulting keys/root token are never
# written to disk in plaintext.
VAULT_TOKEN=

# ---------------------------------------------------------------------
# Kafka (SASL/PLAIN) — one credential pair per role, never shared
# ---------------------------------------------------------------------
KAFKA_BROKER_USER=
KAFKA_BROKER_PASSWORD=
KAFKA_PRODUCER_USER=
KAFKA_PRODUCER_PASSWORD=
KAFKA_CONSUMER_USER=
KAFKA_CONSUMER_PASSWORD=

# ---------------------------------------------------------------------
# MinIO (Bronze/Silver object storage)
# ---------------------------------------------------------------------
# Root credentials — used only by minio-init to bootstrap scoped users below.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# bronze-writer: producer write-only, consumer read-write on bronze/
MINIO_BRONZE_WRITER_ACCESS_KEY=
MINIO_BRONZE_WRITER_SECRET_KEY=
# silver-reader/writer: PySpark job only, read bronze/ + write silver/
MINIO_SILVER_ACCESS_KEY=
MINIO_SILVER_SECRET_KEY=
# gold-reader: dbt/loader read-only on silver/
MINIO_GOLD_READER_ACCESS_KEY=
MINIO_GOLD_READER_SECRET_KEY=

# ---------------------------------------------------------------------
# Postgres — metadata database (Airflow metadata, Great Expectations
# validation results, PII/pipeline audit logs). Local container only;
# never exposed outside the Docker network in production.
# ---------------------------------------------------------------------
POSTGRES_METADATA_USER=
POSTGRES_METADATA_PASSWORD=
AIRFLOW_DB_NAME=airflow
GE_METADATA_DB_NAME=great_expectations
AUDIT_DB_NAME=kovalyx_audit
# Airflow's own connection to its metadata DB. MUST currently be set to
# the same values as POSTGRES_METADATA_USER/PASSWORD above: no separate
# Postgres role is ever created for Airflow specifically (scripts/
# init-multi-db.sh only creates the airflow/great_expectations/
# kovalyx_audit databases, all owned by POSTGRES_METADATA_USER) — using
# a different value here will fail with "password authentication failed"
# since that role doesn't exist. A future migration could provision a
# dedicated least-privilege role here instead.
AIRFLOW_DB_USER=
AIRFLOW_DB_PASSWORD=

# ---------------------------------------------------------------------
# Postgres — local Gold stand-in (docker-compose.yml dev only).
# Mirrors the Supabase schema so `docker compose up` works fully
# offline. Not used in production — see SUPABASE_* below.
# ---------------------------------------------------------------------
GOLD_DB_NAME=kovalyx_gold
GOLD_DB_USER=
GOLD_DB_PASSWORD=

# ---------------------------------------------------------------------
# Supabase (Gold layer, production) — managed Postgres external to the
# Docker network. Used by dbt, the Silver->Gold loader, and Streamlit.
# ---------------------------------------------------------------------
SUPABASE_DB_HOST=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
# Public project URL + anon key — safe for the Next.js browser bundle,
# RLS on the `analytics_reader` role restricts them to mart_ tables only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only service role key — used exclusively in Next.js API routes
# / server components. NEVER prefix with NEXT_PUBLIC_, never ship to client.
SUPABASE_SERVICE_ROLE_KEY=
# Read-only key scoped to the `audit_reader` role, used by Streamlit.
SUPABASE_AUDIT_READER_KEY=
AUDIT_READER_DB_USER=
AUDIT_READER_DB_PASSWORD=

# ---------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=
AIRFLOW_ADMIN_USER=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=

# ---------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# ---------------------------------------------------------------------
# Alerting — pipeline task-failure notifications
# ---------------------------------------------------------------------
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ---------------------------------------------------------------------
# Production domain / TLS (deploy/oracle_cloud_setup.sh, nginx)
# ---------------------------------------------------------------------
KOVALYX_DOMAIN=
LETSENCRYPT_EMAIL=

# ---------------------------------------------------------------------
# Synthetic data generation
# ---------------------------------------------------------------------
FAKER_SEED=42
SEED_DATA_DAYS=90

# ---------------------------------------------------------------------
# Vault AppRole (Silver/GE layer) — spark/silver_transform.py,
# spark/pii_masking.py, and quality/run_checkpoints.py authenticate to
# Vault via AppRole instead of a shared token. role_id/secret_id for the
# kovalyx-silver role are both read from the mounted
# vault/.approle-credentials.json that scripts/vault_init.py produces;
# these two vars are only needed to override that default for local dev.
# ---------------------------------------------------------------------
VAULT_SILVER_ROLE_ID=
VAULT_APPROLE_CREDS_FILE=vault/.approle-credentials.json
# role_id override for scripts/silver_to_postgres_loader.py's kovalyx-gold
# AppRole (secret_id always comes from the mounted credentials file above).
VAULT_GOLD_ROLE_ID=

# ---------------------------------------------------------------------
# Observability — Prometheus Pushgateway for one-shot batch jobs
# (Spark/GE/loader runs aren't long-lived scrape targets, so they push
# instead — see the `pushgateway` service in docker-compose.yml).
# Leave blank to no-op metric pushes entirely.
# ---------------------------------------------------------------------
PROMETHEUS_PUSHGATEWAY_URL=http://pushgateway:9091

# ---------------------------------------------------------------------
# dbt (dbt_project/profiles.yml.example reads these via env_var()) — same
# postgres-gold instance as GOLD_DB_*/SUPABASE_DB_* above, kept as
# separate DBT_PG_* vars since dbt's profile is what an operator runs
# directly from a shell, not just from inside a container.
# ---------------------------------------------------------------------
DBT_PG_HOST=postgres-gold
DBT_PG_PORT=5432
DBT_PG_DATABASE=kovalyx_gold
DBT_PG_USER=
DBT_PG_PASSWORD=
