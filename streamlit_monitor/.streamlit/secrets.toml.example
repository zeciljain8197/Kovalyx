# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git (already covered by the root
# .gitignore's `streamlit_monitor/.streamlit/secrets.toml` entry).
#
# On Streamlit Community Cloud, configure these via the app's Secrets
# management UI (Settings -> Secrets) instead of shipping a file at all —
# Vault is not reachable from Streamlit Cloud's hosted environment, so
# app.py reads st.secrets first and falls back to plain environment
# variables (KOVALYX_PG_HOST etc.) for local `docker compose` runs.

[supabase]
host = "your-supabase-project.supabase.co"
port = 5432
database = "postgres"
# This should be a DB user with the audit_reader ROLE granted (see
# scripts/supabase_schema.sql), not the Supabase service role. Create a
# dedicated DB user in the Supabase dashboard: Settings -> Database -> Users.
user = "audit_reader_user"
password = "your-audit-reader-password"

[app]
admin_password = "your-streamlit-admin-password"
# Used for iframe embeds in the Grafana tab (pages/04_grafana_embed.py).
# Set to http://localhost:8090/grafana for local development.
grafana_base_url = "https://your-domain.com/grafana"
